# Copy to project root .env (git-ignored). Values from Supabase dashboard + NVIDIA NIM.
NIM_API_KEY=nvapi-...
# Supabase → Connect → Session pooler (the direct db.<ref> host is IPv6-only and
# often blocked; the pooler is IPv4 + pgbouncer). Username is postgres.<ref>.
# Session mode = port 5432 (supports DDL/migrations); transaction mode = 6543.
DATABASE_URL=postgresql://postgres.hfvlkcxvxfrvcyyndaum:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
