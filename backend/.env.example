# Copy to project root .env (git-ignored). Values from Supabase dashboard + Groq.
GROQ_API_KEY=gsk_...

# Supabase → Connect → Session pooler (the direct db.<ref> host is IPv6-only and
# often blocked; the pooler is IPv4 + pgbouncer). Username is postgres.<ref>.
# Session mode = port 5432 (supports DDL/migrations); transaction mode = 6543.
DATABASE_URL=postgresql://postgres.hfvlkcxvxfrvcyyndaum:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Search (optional locally — code degrades to empty results if unset):
# Public SearXNG URL. Render free tier cannot use private hostport (juris-searxng:8080).
SEARXNG_URL=https://juris-searxng.onrender.com
# Optional Jina Reader key for higher fetch_page limits; empty still works on the free tier.
JINA_API_KEY=

# LangSmith tracing (optional — unset = no-op, jobs still run):
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=juris
